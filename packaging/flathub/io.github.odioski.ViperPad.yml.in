id: io.github.odioski.ViperPad
runtime: org.freedesktop.Platform
runtime-version: '25.08'
sdk: org.freedesktop.Sdk
sdk-extensions:
  - org.freedesktop.Sdk.Extension.rust-stable
command: viperpad

finish-args:
  - --share=network

modules:
  - name: viperpad
    buildsystem: simple
    build-options:
      append-path: /usr/lib/sdk/rust-stable/bin
      env:
        CARGO_HOME: /run/build/viperpad/cargo
        CARGO_NET_OFFLINE: 'true'
    build-commands:
      - cargo --offline --locked build --release
      - install -Dm0755 target/release/viperpad /app/bin/viperpad
      - install -Dm0644 packaging/linux/io.github.odioski.ViperPad.desktop /app/share/applications/io.github.odioski.ViperPad.desktop
      - install -Dm0644 packaging/linux/io.github.odioski.ViperPad.metainfo.xml /app/share/metainfo/io.github.odioski.ViperPad.metainfo.xml
      - install -Dm0644 packaging/icons/io.github.odioski.ViperPad.png /app/share/icons/hicolor/512x512/apps/io.github.odioski.ViperPad.png
    sources:
      - type: git
        url: @GIT_URL@
        commit: @GIT_COMMIT@
      - cargo-sources.json
